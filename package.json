{
	"name": "sveltekit-2",
	"version": "0.0.1",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"test": "playwright test",
		"test:unit": "vitest",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"postbuild": "npx svelte-sitemap --out-dir .vercel/output/static --domain https://cemilarupa-website.vercel.app/"
	},
	"devDependencies": {
		"@fontsource/fira-mono": "^4.5.10",
		"@neoconfetti/svelte": "^1.0.0",
		"@playwright/test": "^1.40.1",
		"@sveltejs/adapter-vercel": "^3.1.0",
		"@sveltejs/kit": "^1.30.3",
		"@types/cookie": "^0.5.4",
		"@types/lodash": "^4.17.0",
		"autoprefixer": "^10.4.18",
		"eslint": "^8.55.0",
		"eslint-config-prettier": "^8.10.0",
		"eslint-plugin-svelte": "^2.35.1",
		"postcss": "^8.4.35",
		"prettier": "^2.8.8",
		"prettier-plugin-svelte": "^2.10.1",
		"svelte": "^3.59.2",
		"svelte-check": "^3.6.2",
		"tailwindcss": "^3.4.1",
		"typescript": "^5.3.3",
		"vite": "^4.5.1",
		"vitest": "^0.25.8",
		"web-vitals": "^3.5.0"
	},
	"type": "module",
	"dependencies": {
		"@fontsource/barlow-condensed": "^5.0.8",
		"@fontsource/darumadrop-one": "^5.0.17",
		"@fontsource/londrina-solid": "^5.0.18",
		"lodash": "^4.17.21",
		"ol": "^9.0.0",
		"svelte-sitemap": "^2.6.0"
	}
}
